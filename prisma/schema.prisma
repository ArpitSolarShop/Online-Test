generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model TestResult {
  id                String   @id @default(cuid())
  createdAt         DateTime @default(now())
  candidateName     String
  candidatePhone    String
  candidateRole     String
  timeLimitMin      Int
  listeningAnswers  Json
  falseCount        Int
  listeningRating   String
  competencyAnswers Json
  actionScore       Int
  processScore      Int
  peopleScore       Int
  ideaScore         Int
  dominantStyle     String
  totalSelected     Int
  linkId            String?
  pdfPath           String?

  @@index([candidatePhone])
  @@index([createdAt])
  @@index([linkId])
}

model TestLink {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  expiresAt      DateTime
  candidateName  String
  candidatePhone String
  candidateRole  String
  timeLimitMin   Int
  isUsed         Boolean  @default(false)

  @@index([candidatePhone])
  @@index([createdAt])
}
